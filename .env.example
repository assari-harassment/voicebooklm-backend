# Google Cloud Project
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Google OAuth 2.0 (Web Client)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
# Google OAuth 2.0 (iOS Client)
GOOGLE_IOS_CLIENT_ID=aaa.apps.googleusercontent.com

FIREBASE_CREDENTIALS_PATH=/path/to/serviceAccountKey.json
FIREBASE_PROJECT_ID=voicenotelm

# ------------------------------------
# Google Cloud Storage (音声ファイル一時保存)
# ------------------------------------
# バケット名（例: voicebooklm-audio-staging）
GCS_BUCKET_NAME=your-gcs-bucket-name
# リージョン（推奨: asia-northeast2 = 大阪）
GCS_LOCATION=asia-northeast2

# ------------------------------------
# Google Speech-to-Text
# ------------------------------------
# ダウンロードした JSON ファイルを安全な場所に配置してください
# ※ GCS と Speech-to-Text で共通のサービスアカウントを使用
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json

# ------------------------------------
# Google Gemini API (AI Studio)
# ------------------------------------
# https://aistudio.google.com/apikey で取得
GEMINI_API_KEY=your-gemini-api-key
# 使用するモデル（デフォルト: gemini-2.0-flash）
# 選択肢: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-flash-lite など
GEMINI_MODEL=gemini-2.0-flash

# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/voicebooklm
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# ------------------------------------
# CORS Configuration (本番環境用)
# ------------------------------------
# 許可するオリジンを指定（React Native アプリのドメインなど）
# 複数指定する場合は application-prod.yml で直接設定
CORS_ALLOWED_ORIGINS=https://your-production-domain.com
